# これは例であり、実際のトークンは絶対にコミットしないこと。
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# パス（Docker内のパス。マウントと対応させる）
# WORK_SOURCE=/work/source
# WORK_OUTPUT=/work/output
# 注: WORK_OUTPUT 未指定時は WORK_SOURCE/output を使用

# 入力音声ファイル名（WORK_SOURCE 配下に置く）
INPUT_FILENAME=meeting_sample.m4a

# 話者数（未指定なら自動推定）
NUM_SPEAKERS=2

# 話者分離モデル（既定: pyannote/speaker-diarization-3.1）
# MODEL_DIAR=pyannote/speaker-diarization-3.1

# ASR モデル（既定: Qwen/Qwen3-ASR-1.7B）
# MODEL_ASR=Qwen/Qwen3-ASR-1.7B

# ASR 言語（既定: Japanese）
# ASR_LANGUAGE=Japanese
